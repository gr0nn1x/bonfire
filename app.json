{
  "expo": {
    "name": "Bonfire Fitness",
    "slug": "bonfire-fitness",
    "scheme": "bonfire",
    "icon": "./assets/logo.png",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gr0nn1x.bonfire"
    },
    "android": {
      "package": "com.gr0nn1x.bonfire",
      "permissions": ["INTERNET"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1e1b2e"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0b3372b-14eb-4895-b336-1a3303e36360"
      }
    }
  }
}
